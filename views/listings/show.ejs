<% layout("/layouts/boilerplate") %>
<% const bookingSummary = listing?.bookingSummary || {}; %>

<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-lg-8">

      <!-- Back -->
      <a href="/listings" class="btn btn-light btn-sm mb-3">
        <i class="fa-solid fa-arrow-left me-1"></i>Back to Educators
      </a>

      <!-- Main profile card -->
      <div class="show-card card">
        <!-- Profile photo -->
        <img src="<%= listing.image.url %>" alt="<%= listing.name %>" class="card-img-top show-img profile-photo">

        <div class="card-body">
          <!-- Name & badges -->
          <div class="d-flex align-items-center gap-2 flex-wrap mb-3">
            <h3 class="mb-0 fw-bold"><%= listing.name %></h3>
            <% if (listing.verifiedEducator) { %>
              <span class="badge text-bg-success">
                <i class="fa-solid fa-circle-check me-1"></i>Verified Educator
              </span>
            <% } %>
          </div>

          <!-- Quick info chips -->
          <div class="d-flex flex-wrap gap-2 mb-4">
            <span class="subject-badge">
              <i class="fa-solid fa-user-tie"></i><%= listing.educatorType || "Educator" %>
            </span>
            <% if (listing.location) { %>
              <span class="subject-badge">
                <i class="fa-solid fa-location-dot"></i><%= listing.location %>
              </span>
            <% } %>
            <% if (listing.languages) { %>
              <span class="subject-badge">
                <i class="fa-solid fa-language"></i><%= listing.languages %>
              </span>
            <% } %>
            <span class="subject-badge" style="background:var(--nm-primary); color:#fff; border-color:transparent;">
              <i class="fa-solid fa-indian-rupee-sign"></i>
              <%= listing.pricing ? `₹${listing.pricing}/hr` : "Pricing on request" %>
            </span>
          </div>

          <!-- Bio -->
          <% if (listing.bio) { %>
            <div class="mb-4">
              <h5><i class="fa-solid fa-quote-left me-1"></i>About</h5>
              <p style="color:var(--nm-text-muted); line-height:1.75;"><%= listing.bio %></p>
            </div>
          <% } %>

          <!-- Subjects -->
          <% if (listing.subjects && listing.subjects.length) { %>
            <div class="mb-4">
              <h5><i class="fa-solid fa-book-open me-1"></i>Subject Expertise</h5>
              <div class="d-flex flex-wrap gap-2">
                <% for (let subject of listing.subjects) { %>
                  <span class="subject-badge">
                    <%= subject.name %>
                    <span style="opacity:0.6; font-size:0.75rem; font-weight:500;">· <%= subject.level %></span>
                  </span>
                <% } %>
              </div>
            </div>
          <% } %>

          <!-- Availability -->
          <% if (listing.availability) { %>
            <div class="mb-4">
              <h5><i class="fa-solid fa-calendar-days me-1"></i>Availability</h5>
              <div class="d-flex flex-wrap gap-2 mb-2">
                <% const days = Array.isArray(listing.availability.days) ? listing.availability.days : [listing.availability.days]; %>
                <% for (let day of days) { %>
                  <span class="subject-badge"><%= day %></span>
                <% } %>
              </div>
              <p style="color:var(--nm-text-muted); margin:0;">
                <i class="fa-regular fa-clock me-1"></i><%= listing.availability.timeSlots %>
              </p>
            </div>
          <% } %>

          <!-- Student details -->
          <% if (listing.studentDetails) { %>
            <div class="mb-4">
              <h5><i class="fa-solid fa-graduation-cap me-1"></i>Academic Background</h5>
              <div class="row g-2">
                <div class="col-sm-6"><div class="booking-pill"><span>Degree</span><strong><%= listing.studentDetails.degree %></strong></div></div>
                <div class="col-sm-6"><div class="booking-pill"><span>College</span><strong><%= listing.studentDetails.college %></strong></div></div>
                <div class="col-sm-6"><div class="booking-pill"><span>Year / Semester</span><strong><%= listing.studentDetails.yearSemester %></strong></div></div>
                <div class="col-sm-6"><div class="booking-pill"><span>CGPA / Pointer</span><strong><%= listing.studentDetails.cgpaPointer %></strong></div></div>
              </div>
            </div>
          <% } %>

          <!-- Professional details -->
          <% if (listing.professionalDetails) { %>
            <div class="mb-4">
              <h5><i class="fa-solid fa-briefcase me-1"></i>Professional Background</h5>
              <div class="row g-2">
                <div class="col-sm-6"><div class="booking-pill"><span>Job Role</span><strong><%= listing.professionalDetails.jobRole %></strong></div></div>
                <div class="col-sm-6"><div class="booking-pill"><span>Company</span><strong><%= listing.professionalDetails.companyName %></strong></div></div>
                <div class="col-sm-12"><div class="booking-pill"><span>Experience</span><strong><%= listing.professionalDetails.yearsExperience %> years</strong></div></div>
              </div>
            </div>
          <% } %>

          <!-- Social profiles -->
          <% if (listing.socialProfiles) { %>
            <div class="mb-4">
              <h5><i class="fa-solid fa-share-nodes me-1"></i>Social Profiles</h5>
              <div class="d-flex flex-wrap gap-2">
                <% if (listing.socialProfiles.linkedin) { %>
                  <a href="<%= listing.socialProfiles.linkedin %>" target="_blank" rel="noreferrer" class="subject-badge" style="text-decoration:none;">
                    <i class="fa-brands fa-linkedin"></i>LinkedIn
                  </a>
                <% } %>
                <% if (listing.socialProfiles.github) { %>
                  <a href="<%= listing.socialProfiles.github %>" target="_blank" rel="noreferrer" class="subject-badge" style="text-decoration:none;">
                    <i class="fa-brands fa-github"></i>GitHub
                  </a>
                <% } %>
                <% if (listing.socialProfiles.instagram) { %>
                  <a href="<%= listing.socialProfiles.instagram %>" target="_blank" rel="noreferrer" class="subject-badge" style="text-decoration:none;">
                    <i class="fa-brands fa-instagram"></i>Instagram
                  </a>
                <% } %>
                <% if (listing.socialProfiles.portfolio) { %>
                  <a href="<%= listing.socialProfiles.portfolio %>" target="_blank" rel="noreferrer" class="subject-badge" style="text-decoration:none;">
                    <i class="fa-solid fa-globe"></i>Portfolio
                  </a>
                <% } %>
              </div>
            </div>
          <% } %>

          <!-- Identity verification -->
          <% if (listing.identityVerification) { %>
            <div class="mb-2">
              <h5><i class="fa-solid fa-id-card me-1"></i>Identity Verification</h5>
              <div class="booking-pill d-inline-flex gap-2">
                <span>ID Type</span>
                <strong><%= listing.identityVerification.idType %></strong>
                <% if (listing.verifiedEducator) { %>
                  <span class="badge text-bg-success ms-2">Verified</span>
                <% } else { %>
                  <span style="color:var(--nm-warning); font-size:0.82rem; font-weight:600;">⏳ Pending review</span>
                <% } %>
              </div>
            </div>
          <% } %>

        </div><!-- card-body -->
      </div><!-- show-card -->

      <!-- Owner actions -->
      <% if (currUser && currUser._id.equals(listing.owner._id)) { %>
        <div class="btns mt-3">
          <a href="/listings/<%= listing._id %>/edit" class="btn btn-primary">
            <i class="fa-solid fa-pen me-1"></i>Edit Profile
          </a>
          <form action="/listings/<%= listing._id %>?_method=DELETE" method="post" class="m-0">
            <button class="btn btn-outline-dark">
              <i class="fa-solid fa-trash me-1"></i>Delete
            </button>
          </form>
        </div>

        <!-- Problems / Questions section -->
        <div class="problem-section mt-4">
          <h4 class="fw-bold mb-1" style="color:var(--nm-text);">
            <i class="fa-solid fa-circle-question me-2" style="color:var(--nm-primary);"></i>Any Problem?
          </h4>
          <p class="text-muted mb-3" style="font-size:0.92rem;">
            Your query or problem is safe with us and will resolve asap.
          </p>

          <form action="/listings/<%= listing._id %>/stu_problem" method="post" novalidate class="needs-validation mb-4">
            <div class="mb-3">
              <label for="rating" class="form-label">
                Urgency Level <span id="rating-display" style="color:var(--nm-primary); font-weight:700;"></span>
              </label>
              <input type="range" min="1" max="5" id="rating" name="stu_problem[rating]"
                class="form-range" style="accent-color:var(--nm-primary);"
                oninput="document.getElementById('rating-display').textContent = this.value + '/5'">
            </div>
            <div class="mb-3">
              <label for="problem" class="form-label">Describe Your Problem</label>
              <textarea name="stu_problem[problem]" id="problem" rows="4"
                class="form-control" placeholder="Describe the issue or problem you are facing..." required></textarea>
              <div class="invalid-feedback">Please describe the problem before submitting.</div>
            </div>
            <button class="btn btn-primary">
              <i class="fa-solid fa-paper-plane me-2"></i>Submit Problem
            </button>
          </form>

          <!-- Existing problems -->
          <% if (listing.stu_problems && listing.stu_problems.length) { %>
            <h6 class="fw-bold mb-2" style="color:var(--nm-text-muted);">Submitted Problems</h6>
            <% for (let stu_problem of listing.stu_problems) { %>
              <div class="problem-card d-flex justify-content-between align-items-start gap-2">
                <p class="mb-0" style="color:var(--nm-text); flex:1;"><%= stu_problem.problem %></p>
                <form method="post" action="/listings/<%= listing._id %>/stu_problem/<%= stu_problem._id %>?_method=DELETE" class="m-0 flex-shrink-0">
                  <button class="btn btn-sm btn-outline-dark">
                    <i class="fa-solid fa-trash"></i>
                  </button>
                </form>
              </div>
            <% } %>
          <% } else { %>
            <p style="color:var(--nm-text-muted); font-size:0.9rem;">No problems submitted yet.</p>
          <% } %>
        </div>
      <% } %>

    </div>
  </div>
</div>
