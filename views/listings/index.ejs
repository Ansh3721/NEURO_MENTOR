<% layout("/layouts/boilerplate") %>
<body>
    <h2 class="mt-3">All listings</h2>
    <!-- <form action="/listing/new" method="get">
        <button>Add new listing</button>
    </form> -->
    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 ">
         <% for(listings of allListings){ %>
            <a href="/listings/<%=listings._id %>" class="listing-link">
                        <div class="card col listing-card">
                            <img src="<%= listings.image.url %>" class="card-img-top profile-photo" alt="listing_image "  >
                            <div class="card-img-overlay"></div>
                            <div class="card-body">
                                <p class="card-text">
                                     <b><%= listings.name %></b>
                                     <br>
                                    <%= listings.email %>
                                </p> 
                             </div>
                        </div>
            </a>

         <% } %>
    </div>
</body>

