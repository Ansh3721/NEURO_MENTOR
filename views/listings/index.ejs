<% layout("/layouts/boilerplate") %>
<% const safeSearchVal = typeof searchVal !== 'undefined' ? searchVal : ''; %>

<div class="container py-4">
  <div class="listings-header flex-column flex-md-row align-items-stretch align-items-md-center gap-3">
    <div style="flex: 1;">
      <h2>All Educators</h2>
      <p style="color:var(--nm-text-muted); margin:0; font-size:0.95rem;">Find your perfect mentor to accelerate your learning</p>
    </div>
    
    <!-- Search Bar -->
    <div style="max-width: 450px; width: 100%;">
      <form action="/listings" method="GET">
        <div class="input-group">
          <input type="text" name="q" class="form-control" 
            placeholder="Search by name or subject..." 
            value="<%= safeSearchVal %>" 
            style="border-radius: 99px 0 0 99px !important; padding-left: 1.25rem; font-size: 0.92rem; border-color: var(--nm-border-light);"
          >
          <button type="submit" class="btn btn-primary d-flex align-items-center justify-content-center" 
            style="border-radius: 0 99px 99px 0 !important; padding: 0.5rem 1.25rem; font-size: 0.92rem;"
          >
            <i class="fa-solid fa-magnifying-glass"></i>
          </button>
        </div>
      </form>
    </div>

    <% if (!hasListing) { %>
      <a href="/listings/new" class="btn btn-primary add-btn flex-shrink-0">
        <i class="fa-solid fa-plus me-2"></i>Become an Educator
      </a>
    <% } %>
  </div>

  <% if (safeSearchVal) { %>
    <div class="d-flex align-items-center gap-2 mb-3">
      <span class="badge text-bg-light p-2 px-3 border" style="font-size:0.85rem; font-weight:500;">
        Showing search results for "<strong style="color:var(--nm-primary);"><%= safeSearchVal %></strong>"
      </span>
      <a href="/listings" class="btn btn-sm btn-outline-dark rounded-pill px-3" style="font-size:0.75rem;">Clear Search</a>
    </div>
  <% } %>

  <% if (allListings.length === 0) { %>
    <% if (safeSearchVal) { %>
      <!-- No search results state -->
      <div class="profile-state-card text-center py-5 mt-3">
        <i class="fa-solid fa-users-slash" style="font-size:3rem; color:var(--nm-primary); opacity:0.4;"></i>
        <h4 class="mt-3 fw-bold">No educators found</h4>
        <p class="text-muted">No profiles matched your search for "<%= safeSearchVal %>". Try searching for subjects like "math", "java", or a different name.</p>
        <a href="/listings" class="btn btn-primary mt-2">View All Educators</a>
      </div>
    <% } else { %>
      <!-- General empty state -->
      <div class="profile-state-card text-center py-5 mt-3">
        <i class="fa-solid fa-chalkboard-user" style="font-size:3rem; color:var(--nm-primary); opacity:0.4;"></i>
        <h4 class="mt-3 fw-bold">No educators yet</h4>
        <p class="text-muted">Be the first to create an educator profile!</p>
        <a href="/listings/new" class="btn btn-primary">Get Started</a>
      </div>
    <% } %>
  <% } else { %>
    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 g-3">
      <% for (let listings of allListings) { %>
        <div class="col">
          <a href="/listings/<%= listings._id %>" class="listing-link">
            <div class="listing-card card">
              <img src="<%= listings.image.url %>" class="card-img-top profile-photo" alt="<%= listings.name %>">
              <div class="card-body">
                <div class="d-flex align-items-start justify-content-between gap-2 mb-1">
                  <strong class="card-text" style="font-size:1rem; color:var(--nm-text);">
                    <%= listings.name %>
                  </strong>
                  <% if (listings.verifiedEducator) { %>
                    <span class="badge text-bg-success flex-shrink-0">
                      <i class="fa-solid fa-circle-check me-1"></i>Verified
                    </span>
                  <% } %>
                </div>
                <p class="card-text mb-1">
                  <span style="color:var(--nm-primary); font-weight:600; font-size:0.85rem;">
                    <%= listings.educatorType || "Educator" %>
                  </span>
                  <% if (listings.location) { %>
                    <span style="color:var(--nm-text-muted);">
                      &nbsp;·&nbsp;<i class="fa-solid fa-location-dot" style="font-size:0.75rem;"></i> <%= listings.location %>
                    </span>
                  <% } %>
                </p>
                <p class="card-text" style="font-weight:700; color:var(--nm-primary-dark); margin:0;">
                  <%= listings.pricing ? `₹${listings.pricing}/hr` : "Pricing on request" %>
                </p>
              </div>
            </div>
          </a>
        </div>
      <% } %>
    </div>
  <% } %>
</div>
