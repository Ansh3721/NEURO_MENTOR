<% layout("/layouts/boilerplate") %>

<div class="error-shell">
  <div class="error-card">
    <div class="error-code mb-2">
      <i class="fa-solid fa-triangle-exclamation" style="color:var(--nm-primary);"></i>
    </div>
    <h2 class="fw-bold mb-2" style="color:var(--nm-text); letter-spacing:-0.02em;">Oops!</h2>
    <p style="color:var(--nm-text-muted); font-size:1.05rem; margin-bottom:1.75rem;">
      <%= message %>
    </p>
    <div class="d-flex gap-2 justify-content-center">
      <a href="/" class="btn btn-primary" style="border-radius:999px !important; padding:0.65rem 1.75rem !important;">
        <i class="fa-solid fa-house me-2"></i>Go Home
      </a>
      <a href="/listings" class="btn btn-light" style="border-radius:999px !important; padding:0.65rem 1.5rem !important;">
        Browse Educators
      </a>
    </div>
  </div>
</div>